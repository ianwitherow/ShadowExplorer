<Window x:Class="ShadowExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Shadow Explorer" Height="650" Width="950"
        MinHeight="400" MinWidth="600"
        Background="{StaticResource BgPrimary}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- ListView item style for dark theme -->
        <Style x:Key="DarkListViewItem" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3a3a5c"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30304a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark column header with proper hover -->
        <Style x:Key="HeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
            <Setter Property="Foreground" Value="{StaticResource FgSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,1"
                                    Padding="8,6">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <!-- Thumb for column resizing -->
                            <Thumb x:Name="PART_HeaderGripper" HorizontalAlignment="Right" Width="4"
                                   Margin="0" Cursor="SizeWE" Background="Transparent">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent" Width="4"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3a3a58"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#44446a"/>
                            </Trigger>
                            <!-- Hide the filler/padding header -->
                            <Trigger Property="Role" Value="Padding">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgTertiary}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,0,1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark context menu -->
        <Style x:Key="DarkContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource BgSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
            <Setter Property="Padding" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="24,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Header}" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3a3a5c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkSeparator" TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Height" Value="1"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
            <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#404068"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#505078"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgSecondary}" Padding="16,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Shadow Explorer" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBlue}" Margin="0,0,0,4"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnUpLevel" Grid.Column="1"
                            Style="{StaticResource ActionButton}"
                            Click="BtnUpLevel_Click"
                            Padding="6,3" Margin="0,0,8,0"
                            ToolTip="Navigate to parent folder">
                        <Path Data="M4,0 L8,5 L5,5 L5,9 L3,9 L3,5 L0,5 Z"
                              Fill="{StaticResource FgPrimary}" Width="10" Height="11" Stretch="Uniform"/>
                    </Button>
                    <TextBlock Grid.Column="2" Text="Path: " Foreground="{StaticResource FgSecondary}"
                               VerticalAlignment="Center" FontSize="13"/>

                    <!-- Click-to-edit path: TextBlock shown by default, TextBox on click -->
                    <TextBlock x:Name="PathDisplay" Grid.Column="3" Foreground="{StaticResource FgPrimary}"
                               VerticalAlignment="Center" FontSize="13" TextTrimming="CharacterEllipsis"
                               Cursor="Hand"
                               ToolTip="Click to edit path"
                               MouseLeftButtonDown="PathDisplay_MouseLeftButtonDown"/>
                    <TextBox x:Name="PathEdit" Grid.Column="3" Visibility="Collapsed"
                             Background="{StaticResource BgTertiary}"
                             Foreground="{StaticResource FgPrimary}"
                             BorderBrush="{StaticResource AccentBlue}"
                             BorderThickness="1" FontSize="13"
                             Padding="4,2" VerticalAlignment="Center"
                             KeyDown="PathEdit_KeyDown"
                             LostFocus="PathEdit_LostFocus"/>

                    <TextBlock x:Name="ModeDisplay" Grid.Column="4" Foreground="{StaticResource AccentYellow}"
                               VerticalAlignment="Center" FontSize="12" Margin="12,0,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Main content area with splitter -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="PreviewColumn" Width="300" MinWidth="100"/>
            </Grid.ColumnDefinitions>

            <!-- File versions list (file mode) -->
            <ListView x:Name="VersionsList" Grid.Column="0"
                      Background="{StaticResource BgPrimary}"
                      BorderThickness="0"
                      ItemContainerStyle="{StaticResource DarkListViewItem}"
                      SelectionChanged="VersionsList_SelectionChanged"
                      MouseMove="VersionsList_MouseMove"
                      Visibility="Visible">
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource HeaderStyle}">
                        <GridViewColumn Header="Snapshot Date" Width="170"
                                        DisplayMemberBinding="{Binding DateDisplay}"/>
                        <GridViewColumn Header="File Modified" Width="170"
                                        DisplayMemberBinding="{Binding ModifiedDisplay}"/>
                        <GridViewColumn Header="Size" Width="100"
                                        DisplayMemberBinding="{Binding SizeDisplay}"/>
                        <GridViewColumn Header="Status" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Shadow"/>
                                                <Setter Property="Foreground" Value="{StaticResource FgSecondary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrentVersion}" Value="True">
                                                        <Setter Property="Text" Value="Current"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
                <ListView.ContextMenu>
                    <ContextMenu Style="{StaticResource DarkContextMenu}">
                        <MenuItem Header="Open in Default App" Click="OpenFile_Click" Style="{StaticResource DarkMenuItem}"/>
                        <MenuItem Header="Copy File" Click="CopyFile_Click" Style="{StaticResource DarkMenuItem}"/>
                        <MenuItem Header="Save As..." Click="SaveAs_Click" Style="{StaticResource DarkMenuItem}"/>
                        <Separator Style="{StaticResource DarkSeparator}"/>
                        <MenuItem Header="Restore (Replace Current)" Click="RestoreFile_Click"
                                  Style="{StaticResource DarkMenuItem}" Foreground="{StaticResource AccentYellow}"/>
                    </ContextMenu>
                </ListView.ContextMenu>
            </ListView>

            <!-- Folder file list (folder mode) -->
            <ListView x:Name="FolderList" Grid.Column="0"
                      Background="{StaticResource BgPrimary}"
                      BorderThickness="0"
                      ItemContainerStyle="{StaticResource DarkListViewItem}"
                      MouseDoubleClick="FolderList_MouseDoubleClick"
                      Visibility="Collapsed">
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource HeaderStyle}">
                        <GridViewColumn Header="File Name" Width="280">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileName}"
                                               Foreground="{Binding ExistsCurrently, Converter={StaticResource DeletedForeground}}"
                                               FontStyle="{Binding ExistsCurrently, Converter={StaticResource ExistsFontStyle}}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Status" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusDisplay}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ExistsCurrently}" Value="False">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentRed}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource FgSecondary}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Current Size" Width="100"
                                        DisplayMemberBinding="{Binding SizeDisplay}"/>
                        <GridViewColumn Header="Versions" Width="80"
                                        DisplayMemberBinding="{Binding VersionCount}"/>
                        <GridViewColumn Header="Last Modified" Width="170">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LatestModified, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                               Foreground="{StaticResource FgPrimary}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
                <ListView.ContextMenu>
                    <ContextMenu Style="{StaticResource DarkContextMenu}">
                        <MenuItem Header="View Version History" Click="FolderList_OpenItem_Click" Style="{StaticResource DarkMenuItem}"/>
                    </ContextMenu>
                </ListView.ContextMenu>
            </ListView>

            <GridSplitter Grid.Column="1" Width="3" Background="{StaticResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- Preview pane -->
            <Border Grid.Column="2" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource BgTertiary}" Padding="10,8"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Preview" Foreground="{StaticResource FgSecondary}"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                    <TextBox x:Name="PreviewText" Grid.Row="1"
                             Background="{StaticResource BgSecondary}"
                             Foreground="{StaticResource FgPrimary}"
                             FontFamily="Consolas" FontSize="12"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             BorderThickness="0" Padding="10,8"
                             Text="Select a version to preview"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource BgSecondary}" Padding="12,8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0"
                           Foreground="{StaticResource FgSecondary}" FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="DragHint" Grid.Column="1"
                           Text="Drag versions to Explorer to copy, or right-click for more options"
                           Foreground="{StaticResource FgSecondary}" FontSize="11"
                           VerticalAlignment="Center" FontStyle="Italic"/>
            </Grid>
        </Border>

        <!-- Action buttons -->
        <Border Grid.Row="3" Background="{StaticResource BgSecondary}" Padding="12,8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Open" Style="{StaticResource ActionButton}"
                        Click="OpenFile_Click" x:Name="BtnOpen"/>
                <Button Content="Copy" Style="{StaticResource ActionButton}"
                        Click="CopyFile_Click" x:Name="BtnCopy"/>
                <Button Content="Save As..." Style="{StaticResource ActionButton}"
                        Click="SaveAs_Click" x:Name="BtnSaveAs"/>
                <Button Content="Restore" Style="{StaticResource ActionButton}"
                        Click="RestoreFile_Click" x:Name="BtnRestore"
                        Foreground="{StaticResource AccentYellow}"/>
            </StackPanel>
        </Border>

        <!-- Loading overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="4"
                Background="#CC1e1e2e" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Scanning shadow copies..."
                           Foreground="{StaticResource AccentBlue}"
                           FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Foreground="{StaticResource AccentBlue}"
                             Background="{StaticResource BgTertiary}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
